# Dosh Environment Configuration
# Copy this file to .env and adjust values for your deployment.

# Application version — should match the release tag
APP_VERSION=0.6.6-alpha

# Development mode — enables demo budget creation and dev-only UI
DEV_MODE=false

# Database URL — SQLite path inside the container
DATABASE_URL=sqlite:////app/data/dosh.db

# Timezone for budget cycle boundaries and date display
# Must be one of the supported values listed below.
TZ=Australia/Sydney

# Log level for plain-text logging: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ------------------------------------------------------------------------------
# Supported Timezones (uncomment one to use)
# ------------------------------------------------------------------------------
# TZ=Australia/Sydney
# TZ=Australia/Perth
# TZ=Pacific/Auckland
# TZ=America/New_York
# TZ=America/Los_Angeles
# TZ=Europe/London
# TZ=Europe/Berlin
# TZ=UTC
